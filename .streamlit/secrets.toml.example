# ── Streamlit Cloud Secrets 예시 파일 ─────────────────────────────────────
# 이 파일은 GitHub에 올려도 됩니다 (.example이므로 실제 키 없음).
#
# [사용법]
# 1. Streamlit Cloud 대시보드 → 앱 설정 → "Secrets" 탭
# 2. 아래 내용을 복사해서 실제 키 값으로 채운 뒤 저장
#
# 로컬에서 쓸 때는:
#   .streamlit/secrets.toml 파일을 만들고 (gitignore에 차단됨)
#   아래 내용을 실제 키로 채워서 사용하세요.

[api_keys]
GEMINI_API_KEY  = "여기에_실제_Gemini_API_키_입력"
YOUTUBE_API_KEY = "여기에_실제_YouTube_API_키_입력"
